generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contestant {
  id           String   @id @default(uuid())
  name         String
  image_url    String
  votes_total  Int      @default(0)
  createdAt    DateTime @default(now())
}

model Vote {
  id            String   @id @default(uuid())
  userId        String
  contestantId  String
  amount        Int
  createdAt     DateTime @default(now())
}

model UserMemory {
  id        String   @id @default(uuid())
  userId    String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}
