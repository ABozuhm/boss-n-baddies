"use client";

import { useState, useRef, useEffect } from "react";
import VeloraAvatar from "@/components/VeloraAvatar";
import VeloraVoice from "@/components/VeloraVoice";

type Message = {
  role: "user" | "assistant";
  content: string;
};

export default function AIBoo() {
  const [messages, setMessages] = useState<Message[]>([]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);

  const chatEndRef = useRef<HTMLDivElement>(null);

  // 🔽 Auto scroll
  useEffect(() => {
    chatEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  // 🎤 SPEAK FUNCTION (Velora talks)
  const speak = (text: string) => {
    const speech = new SpeechSynthesisUtterance(text);
    speech.pitch = 1.2;
    speech.rate = 1;
    speech.lang = "en-US";

    window.speechSynthesis.cancel(); // stop overlapping
    window.speechSynthesis.speak(speech);
  };

  // 💬 SEND MESSAGE
  const sendMessage = async () => {
    if (!input.trim()) return;

    const newMessages = [
      ...messages,
      { role: "user", content: input }
    ];

    setMessages(newMessages);
    setInput("");
    setLoading(true);

    try {
      const res = await fetch("/api/velora", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          userId: "user-123", // replace with real auth later
          message: input,
          history: messages
        })
      });

      const data = await res.json();

      const updatedMessages = [
        ...newMessages,
        { role: "assistant", content: data.content }
      ];

      setMessages(updatedMessages);

      // 🔊 Velora speaks
      speak(data.content);

    } catch (err) {
      console.error(err);
    }

    setLoading(false);
  };

  // ⌨️ ENTER KEY SEND
  const handleKeyDown = (e: any) => {
    if (e.key === "Enter") sendMessage();
  };

  // 🎤 VOICE INPUT (manual trigger)
  const startVoiceInput = () => {
    const recognition =
      new (window as any).webkitSpeechRecognition();

    recognition.lang = "en-US";

    recognition.onresult = (event: any) => {
      const text = event.results[0][0].transcript;
      setInput(text);
    };

    recognition.start();
  };

  return (
    <div className="h-screen bg-black text-white flex flex-col">

      {/* HEADER */}
      <div className="p-4 border-b border-gray-700 flex justify-between">
        <h1 className="text-2xl font-bold">AI BOO 💋 (Velora)</h1>
        <button
          onClick={startVoiceInput}
          className="bg-purple-500 px-4 py-2 rounded"
        >
          🎤 Speak
        </button>
      </div>

      {/* CHAT WINDOW */}
      <div className="flex-1 overflow-y-auto p-4 space-y-3">
        {messages.map((msg, i) => (
          <div
            key={i}
            className={`max-w-[70%] p-3 rounded-lg ${
              msg.role === "user"
                ? "bg-pink-500 ml-auto"
                : "bg-gray-800"
            }`}
          >
            {msg.content}
          </div>
        ))}

        {loading && (
          <div className="text-gray-400">Velora typing...</div>
        )}

        <div ref={chatEndRef} />
      </div>

      {/* INPUT BAR */}
      <div className="p-4 border-t border-gray-700 flex gap-2">
        <input
          className="flex-1 p-3 rounded bg-gray-900 text-white outline-none"
          placeholder="Talk to Velora..."
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyDown={handleKeyDown}
        />

        <button
          onClick={sendMessage}
          className="bg-pink-500 px-6 rounded"
        >
          Send
        </button>
      </div>

      {/* VELORA AVATAR */}
      <VeloraAvatar />
    </div>
  );
}
